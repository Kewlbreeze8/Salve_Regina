      ],
      "lines": [
        { "speaker": "Unknown", "text": "As I stare into the groggy reflection in the dresser mirror, I can't shake the feeling..." },
        { "speaker": "Unknown", "text": "That something invisible has its grip on me again." },
        { "speaker": "Unknown", "text": ". . ." }
