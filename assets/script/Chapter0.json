      ],
      "lines": [
        { "speaker": "Elsa", "text": "My name is Elsa Maria. I live alone in this house where my parents once did." },
        { "speaker": "Elsa", "text": "They left me behind, My sister is missing..." },
        { "speaker": "Elsa", "text": "All I have left is the silence... and God’s merciless gaze." },
        { "speaker": "Elsa", "text": ". . ." }
      ],
      "next": "Reminder"
